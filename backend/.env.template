# ==========================================
# Database Container Config (For MySQL image)
# ==========================================
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
MYSQL_DATABASE=ccf_gpus

# ==========================================
# Backend Server Config (For Go app)
# ==========================================
PORT=8080
GIN_MODE=release

# Database Connection
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_root_password_here
DB_NAME=ccf_gpus

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password_here

# ==========================================
# Security & Secrets
# ==========================================
# JWT Secret
# To generate a secure random hex string, run this in your terminal:
# openssl rand -hex 32
JWT_SECRET=your_generated_jwt_secret_here

# Encryption Key
# To generate a secure base64 string, run this in your terminal:
# openssl rand -base64 24
ENCRYPTION_KEY=your_generated_encryption_key_here

# ==========================================
# SMTP Configuration (Email/OTP)
# ==========================================
# For LOCAL DEV / TESTING: Leave EMAIL and PASSWORD blank.
# The OTP will be printed directly to the terminal logs.
#
# For PRODUCTION: Fill these in with your real app credentials.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_google_app_password_here

# ==========================================
# Notification Emails (Comma-separated)
# ==========================================
NOTIFICATION_EMAILS=
